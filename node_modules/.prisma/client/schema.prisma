// ─────────────────────────────────────────────
// ENTERPRISE LAYER — AUDIT, EVENTS, PERMISSIONS
// ─────────────────────────────────────────────

// Immutable audit ledger — NEVER update or delete
model AuditLog {
  id            String          @id @default(auto()) @map("_id") @db.ObjectId
  entityType    AuditEntityType
  entityId      String          @db.ObjectId
  action        AuditAction
  performedById String          @db.ObjectId
  beforeState   String? // JSON snapshot
  afterState    String? // JSON snapshot
  ipAddress     String?
  deviceInfo    String?
  userAgent     String?
  metadata      String? // JSON
  createdAt     DateTime        @default(now())

  performedBy User @relation(fields: [performedById], references: [id])

  @@index([entityType])
  @@index([entityId])
  @@index([entityType, entityId])
  @@index([entityType, entityId, createdAt])
  @@index([performedById])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

// Analytics event stream — TTL 180 days on createdAt
model UserEvent {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  userId      String?   @db.ObjectId
  fingerprint String? // anonymous session token
  eventType   EventType
  entityType  String? // "blog" | "listing" | "disease_report" etc.
  entityId    String?   @db.ObjectId
  districtId  String?   @db.ObjectId
  source      String? // "search" | "community" | "notification" | "direct"
  metadata    String? // JSON
  createdAt   DateTime  @default(now()) // TTL target

  user     User?     @relation(fields: [userId], references: [id])
  district District? @relation(fields: [districtId], references: [id])

  @@index([userId])
  @@index([eventType])
  @@index([entityId])
  @@index([districtId])
  @@index([userId, eventType])
  @@index([entityType, entityId, eventType])
  @@index([createdAt]) // TTL target
  @@map("user_events")
}

// Actor-centric admin action log
model AdminActivityLog {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  adminId    String   @db.ObjectId
  action     String // "SUSPENDED_USER", "RELEASED_MILESTONE" etc.
  targetType String
  targetId   String   @db.ObjectId
  reason     String?
  notes      String?
  ipAddress  String?
  deviceInfo String?
  createdAt  DateTime @default(now())

  admin User @relation(fields: [adminId], references: [id])

  @@index([adminId])
  @@index([targetType])
  @@index([targetId])
  @@index([action])
  @@index([createdAt])
  @@index([adminId, createdAt])
  @@map("admin_activity_logs")
}

// Role × Resource × Action permission matrix
model RolePermission {
  id          String             @id @default(auto()) @map("_id") @db.ObjectId
  role        UserRole
  resource    PermissionResource
  action      PermissionAction
  isAllowed   Boolean            @default(true)
  createdById String             @db.ObjectId
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  createdBy User @relation(fields: [createdById], references: [id])

  @@unique([role, resource, action])
  @@index([role])
  @@index([resource])
  @@map("role_permissions")
}

// Per-user permission exceptions — grant or revoke beyond role defaults
model UserPermissionOverride {
  id          String             @id @default(auto()) @map("_id") @db.ObjectId
  userId      String             @db.ObjectId
  resource    PermissionResource
  action      PermissionAction
  isAllowed   Boolean // true = grant, false = explicit deny
  reason      String?
  grantedById String             @db.ObjectId
  expiresAt   DateTime?
  createdAt   DateTime           @default(now())

  user      User @relation("PermissionOverrideUser", fields: [userId], references: [id])
  grantedBy User @relation("PermissionOverrideGrantedBy", fields: [grantedById], references: [id])

  @@unique([userId, resource, action])
  @@index([userId])
  @@index([expiresAt])
  @@map("user_permission_overrides")
}

// Feature flag toggles — scoped rollout per role/district/user
model FeatureFlag {
  id  String @id @default(auto()) @map("_id") @db.ObjectId
  key String @unique

  description       String?
  isEnabled         Boolean  @default(false)
  enabledRoles      String[] @default([]) // UserRole values
  enabledDistricts  String[] @default([]) @db.ObjectId
  enabledUserIds    String[] @default([]) @db.ObjectId
  rolloutPercentage Int      @default(100)
  createdById       String   @db.ObjectId
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  createdBy User @relation(fields: [createdById], references: [id])

  @@index([isEnabled])
  @@map("feature_flags")
}

// System-wide tunable config — read at startup, cached
model GlobalConfig {
  id  String @id @default(auto()) @map("_id") @db.ObjectId
  key String @unique

  value       String
  valueType   String // "int" | "float" | "bool" | "string" | "json"
  description String?
  isSensitive Boolean  @default(false)
  updatedById String?  @db.ObjectId
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  updatedBy User? @relation(fields: [updatedById], references: [id])

  @@map("global_config")
}

// Rate limiting tracker — TTL 24 hours on windowStart
model RateLimitLog {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  userId       String   @db.ObjectId
  action       String // "disease_report_submit" | "loan_pledge" | "chat_message" etc.
  windowStart  DateTime // floored to hour — TTL target
  requestCount Int      @default(1)
  ipAddress    String?
  isBlocked    Boolean  @default(false)

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, action, windowStart])
  @@index([userId])
  @@index([action])
  @@index([isBlocked])
  @@index([windowStart]) // TTL target
  @@map("rate_limit_logs")
}

// ─────────────────────────────────────────────
// NEW MARKETPLACE MODULE (REQUEST-BASED)
// ─────────────────────────────────────────────

enum MarketplaceCategory {
  CROPS
  FRUITS
  VEGETABLES
  GRAINS
  SEEDS
  FERTILIZERS
  PESTICIDES
  FARMING_EQUIPMENT
  LIVESTOCK_PRODUCTS
  OTHER
}

enum MarketplaceItemStatus {
  ACTIVE
  INACTIVE
  SOLD
}

enum MarketplaceDemandStatus {
  OPEN
  FULFILLED
  CLOSED
}

enum MarketplaceRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model MarketplaceNewItem {
  id           String                @id @default(auto()) @map("_id") @db.ObjectId
  sellerId     String                @db.ObjectId
  itemName     String
  category     MarketplaceCategory
  quantity     String
  pricePerUnit Float
  location     String
  description  String?
  imageUrl     String?
  status       MarketplaceItemStatus @default(ACTIVE)
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  seller           User                            @relation("SellerItems", fields: [sellerId], references: [id])
  purchaseRequests MarketplaceNewPurchaseRequest[]
  reports          ContentReport[]                 @relation("ContentReportNewItem")

  @@index([sellerId])
  @@index([category])
  @@index([status])
  @@map("marketplace_new_items")
}

model MarketplaceNewDemand {
  id             String                  @id @default(auto()) @map("_id") @db.ObjectId
  buyerId        String                  @db.ObjectId
  itemName       String
  category       MarketplaceCategory
  quantityNeeded String
  expectedPrice  Float
  location       String
  description    String?
  status         MarketplaceDemandStatus @default(OPEN)
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  buyer   User                        @relation("BuyerDemands", fields: [buyerId], references: [id])
  offers  MarketplaceNewDemandOffer[]
  reports ContentReport[]             @relation("ContentReportNewDemand")

  @@index([buyerId])
  @@index([category])
  @@index([status])
  @@map("marketplace_new_demands")
}

model MarketplaceNewPurchaseRequest {
  id                String                   @id @default(auto()) @map("_id") @db.ObjectId
  itemId            String                   @db.ObjectId
  buyerId           String                   @db.ObjectId
  sellerId          String                   @db.ObjectId
  requestedQuantity String
  message           String?
  status            MarketplaceRequestStatus @default(PENDING)
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  item   MarketplaceNewItem @relation(fields: [itemId], references: [id])
  buyer  User               @relation("BuyerRequests", fields: [buyerId], references: [id])
  seller User               @relation("SellerRequests", fields: [sellerId], references: [id])

  @@index([itemId])
  @@index([buyerId])
  @@index([sellerId])
  @@map("marketplace_new_purchase_requests")
}

model MarketplaceNewDemandOffer {
  id                String                   @id @default(auto()) @map("_id") @db.ObjectId
  demandId          String                   @db.ObjectId
  sellerId          String                   @db.ObjectId
  buyerId           String                   @db.ObjectId
  quantityAvailable String
  offeredPrice      Float
  message           String?
  status            MarketplaceRequestStatus @default(PENDING)
  createdAt         DateTime                 @updatedAt
  updatedAt         DateTime                 @updatedAt

  demand MarketplaceNewDemand @relation(fields: [demandId], references: [id])
  seller User                 @relation("SellerOffers", fields: [sellerId], references: [id])
  buyer  User                 @relation("BuyerOffers", fields: [buyerId], references: [id])

  @@index([demandId])
  @@index([sellerId])
  @@index([buyerId])
  @@map("marketplace_new_demand_offers")
}

enum AssetType {
  PROPERTY
  VEHICLE
  EQUIPMENT
  OTHER
}

enum AssetStatus {
  AVAILABLE // open for bids
  LOCKED // bid accepted, rental active or pending start
  INACTIVE // owner took it off the market
}

enum BidStatus {
  PENDING // awaiting owner decision
  ACCEPTED // owner chose this bidder → tenant
  REJECTED // owner rejected, or auto-rejected on another bid acceptance
  WITHDRAWN // bidder cancelled their own bid
}

enum RentalStatus {
  UPCOMING // deal closed, rental hasn't started yet
  ACTIVE // currently rented
  COMPLETED // rental period ended
  CANCELLED // cancelled after closing (edge case)
}

model Asset {
  id      String @id @default(cuid()) @map("_id")
  ownerId String
  owner   User   @relation("OwnedAssets", fields: [ownerId], references: [id])

  title       String
  description String
  type        AssetType
  status      AssetStatus @default(AVAILABLE)

  // Pricing hint — bidders can bid above/below this
  basePrice Float

  bids   Bid[]
  rental Rental?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Bid {
  id      String @id @default(cuid()) @map("_id")
  assetId String
  asset   Asset  @relation(fields: [assetId], references: [id])

  bidderId String
  bidder   User   @relation("PlacedBids", fields: [bidderId], references: [id])

  amount Float
  status BidStatus @default(PENDING)

  // Proposed rental window from the bidder
  startDate DateTime
  endDate   DateTime

  message String? // optional note to owner

  rental Rental? // populated only if this bid was accepted

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([assetId])
  @@index([bidderId])
}

model Rental {
  id      String @id @default(cuid()) @map("_id")
  assetId String @unique // one active rental per asset
  asset   Asset  @relation(fields: [assetId], references: [id])

  bidId String @unique // the winning bid
  bid   Bid    @relation(fields: [bidId], references: [id])

  tenantId String
  tenant   User   @relation("ActiveRentals", fields: [tenantId], references: [id])

  startDate   DateTime
  endDate     DateTime
  agreedPrice Float

  status RentalStatus @default(UPCOMING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}
