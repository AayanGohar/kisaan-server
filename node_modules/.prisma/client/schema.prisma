// ─────────────────────────────────────────────
// BLOG SYSTEM
// ─────────────────────────────────────────────

model BlogCategory {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String   @unique
  slug        String   @unique
  parentId    String?  @db.ObjectId
  description String?
  iconUrl     String?
  sortOrder   Int      @default(0)
  isDeleted   Boolean  @default(false)
  createdAt   DateTime @default(now())

  parent   BlogCategory?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children BlogCategory[] @relation("CategoryTree")
  blogs    Blog[]

  @@index([parentId])
  @@index([isDeleted])
  @@map("blog_categories")
}

model Blog {
  id              String       @id @default(auto()) @map("_id") @db.ObjectId
  authorId        String       @db.ObjectId
  categoryId      String?      @db.ObjectId
  title           String
  slug            String       @unique
  summary         String?
  content         String
  coverImageUrl   String?
  tags            String[]     @default([])
  catalogId       String?      @db.ObjectId
  audience        BlogAudience @default(GENERAL)
  isNational      Boolean      @default(true)
  stateId         String?      @db.ObjectId
  districtId      String?      @db.ObjectId
  hasLocation     Boolean      @default(false)
  latitude        Float?
  longitude       Float?
  metaTitle       String?
  metaDescription String?
  status          BlogStatus   @default(DRAFT)
  isFeatured      Boolean      @default(false)
  viewCount       Int          @default(0)
  likeCount       Int          @default(0)
  commentCount    Int          @default(0)
  publishedAt     DateTime?

  // Soft delete
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?   @db.ObjectId

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  author         User            @relation(fields: [authorId], references: [id])
  category       BlogCategory?   @relation(fields: [categoryId], references: [id])
  catalog        CropCatalog?    @relation("BlogCropCatalog", fields: [catalogId], references: [id])
  state          State?          @relation("BlogState", fields: [stateId], references: [id])
  district       District?       @relation("BlogDistrict", fields: [districtId], references: [id])
  views          BlogView[]
  reactions      BlogReaction[]
  comments       BlogComment[]
  bookmarks      BlogBookmark[]
  contentReports ContentReport[] @relation("ContentReportBlog")

  @@index([authorId])
  @@index([categoryId])
  @@index([status])
  @@index([isFeatured])
  @@index([isNational])
  @@index([stateId])
  @@index([districtId])
  @@index([audience])
  @@index([isDeleted])
  @@index([status, publishedAt])
  @@index([status, isNational])
  @@index([status, stateId])
  @@index([latitude, longitude]) // 2dsphere — field-report geo blogs
  @@map("blogs")
}

// Unique view tracking — prevents bot inflation of viewCount
// TTL: 180 days on createdAt
model BlogView {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  blogId      String   @db.ObjectId
  userId      String?  @db.ObjectId
  fingerprint String? // anonymous browser fingerprint
  source      String? // "community_post" | "search" | "direct" | "notification"
  createdAt   DateTime @default(now()) // TTL target

  blog Blog  @relation(fields: [blogId], references: [id])
  user User? @relation(fields: [userId], references: [id])

  @@index([blogId])
  @@index([userId])
  @@index([blogId, userId])
  @@index([blogId, fingerprint])
  @@index([createdAt]) // TTL target
  @@map("blog_views")
}

model BlogReaction {
  id        String           @id @default(auto()) @map("_id") @db.ObjectId
  blogId    String           @db.ObjectId
  userId    String           @db.ObjectId
  type      PostReactionType @default(LIKE)
  createdAt DateTime         @default(now())

  blog Blog @relation(fields: [blogId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@unique([blogId, userId])
  @@index([blogId])
  @@map("blog_reactions")
}

model BlogComment {
  id       String  @id @default(auto()) @map("_id") @db.ObjectId
  blogId   String  @db.ObjectId
  authorId String  @db.ObjectId
  parentId String? @db.ObjectId

  content String

  // Soft delete
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?   @db.ObjectId

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  blog    Blog          @relation(fields: [blogId], references: [id])
  author  User          @relation(fields: [authorId], references: [id])
  parent  BlogComment?  @relation("BlogCommentReplies", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  replies BlogComment[] @relation("BlogCommentReplies")

  @@index([blogId])
  @@index([authorId])
  @@index([parentId])
  @@index([isDeleted])
  @@index([blogId, createdAt])
  @@map("blog_comments")
}

model BlogBookmark {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  blogId    String   @db.ObjectId
  userId    String   @db.ObjectId
  createdAt DateTime @default(now())

  blog Blog @relation(fields: [blogId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@unique([blogId, userId])
  @@index([userId])
  @@map("blog_bookmarks")
}

