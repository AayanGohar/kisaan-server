// ─────────────────────────────────────────────
// CROWDFUNDING (FULL ESCROW LIFECYCLE)
// ─────────────────────────────────────────────

model LoanRequest {
  id             String     @id @default(auto()) @map("_id") @db.ObjectId
  farmerId       String     @db.ObjectId
  communityId    String?    @db.ObjectId
  title          String
  amount         Float
  pledgedAmount  Float      @default(0) // cached SUM — source of truth is LoanPledge
  reason         String
  description    String?
  proofDocs      String[]   @default([])
  repaymentPlan  String?
  deadline       DateTime?
  status         LoanStatus @default(OPEN)
  supporterCount Int        @default(0)
  pledgerCount   Int        @default(0)

  // Soft delete
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?   @db.ObjectId

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  farmer     FarmerProfile   @relation(fields: [farmerId], references: [id])
  community  Community?      @relation(fields: [communityId], references: [id])
  fundWallet LoanFundWallet?
  milestones LoanMilestone[]
  pledges    LoanPledge[]
  repayments LoanRepayment[]
  votes      LoanVote[]

  @@index([farmerId])
  @@index([communityId])
  @@index([status])
  @@index([isDeleted])
  @@index([status, createdAt])
  @@map("loan_requests")
}

model LoanFundWallet {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  loanId         String   @unique @db.ObjectId
  totalPledged   Float    @default(0)
  heldAmount     Float    @default(0)
  releasedAmount Float    @default(0)
  refundedAmount Float    @default(0)
  lastEventAt    DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  loan LoanRequest @relation(fields: [loanId], references: [id])

  @@map("loan_fund_wallets")
}

model LoanMilestone {
  id              String              @id @default(auto()) @map("_id") @db.ObjectId
  loanId          String              @db.ObjectId
  title           String
  description     String?
  amount          Float
  dueDate         DateTime?
  status          LoanMilestoneStatus @default(PENDING)
  completionProof String[]            @default([])
  completedAt     DateTime?
  releasedAt      DateTime?
  approvedById    String?             @db.ObjectId
  sortOrder       Int                 @default(0)
  createdAt       DateTime            @default(now())

  loan       LoanRequest @relation(fields: [loanId], references: [id])
  approvedBy User?       @relation("MilestoneApprovedBy", fields: [approvedById], references: [id])

  @@index([loanId])
  @@index([status])
  @@index([loanId, sortOrder])
  @@map("loan_milestones")
}

model LoanPledge {
  id              String       @id @default(auto()) @map("_id") @db.ObjectId
  loanId          String       @db.ObjectId
  pledgerId       String       @db.ObjectId
  amount          Float
  message         String?
  isAnonymous     Boolean      @default(false)
  status          PledgeStatus @default(HELD)
  statusChangedAt DateTime?
  statusChangedBy String?      @db.ObjectId
  pledgeIp        String?
  pledgeDevice    String?
  createdAt       DateTime     @default(now())

  loan                   LoanRequest                 @relation(fields: [loanId], references: [id])
  pledger                User                        @relation(fields: [pledgerId], references: [id])
  repaymentDistributions LoanRepaymentDistribution[]

  @@unique([loanId, pledgerId])
  @@index([loanId])
  @@index([pledgerId])
  @@index([status])
  @@index([loanId, status])
  @@map("loan_pledges")
}

model LoanRepayment {
  id               String          @id @default(auto()) @map("_id") @db.ObjectId
  loanId           String          @db.ObjectId
  farmerId         String          @db.ObjectId
  installmentNo    Int
  amountDue        Float
  amountPaid       Float           @default(0)
  dueDate          DateTime
  paidDate         DateTime?
  status           RepaymentStatus @default(SCHEDULED)
  paymentReference String?
  notes            String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  loan          LoanRequest                 @relation(fields: [loanId], references: [id])
  farmer        FarmerProfile               @relation(fields: [farmerId], references: [id])
  distributions LoanRepaymentDistribution[]

  @@unique([loanId, installmentNo])
  @@index([loanId])
  @@index([farmerId])
  @@index([status])
  @@index([dueDate])
  @@index([farmerId, status])
  @@index([status, dueDate]) // cron finds overdue here
  @@map("loan_repayments")
}

model LoanRepaymentDistribution {
  id          String          @id @default(auto()) @map("_id") @db.ObjectId
  repaymentId String          @db.ObjectId
  loanId      String          @db.ObjectId
  pledgeId    String          @db.ObjectId
  pledgerId   String          @db.ObjectId
  pledgeShare Float // pledger's % of total loan
  amountDue   Float
  amountPaid  Float           @default(0)
  status      RepaymentStatus @default(SCHEDULED)
  paidAt      DateTime?
  createdAt   DateTime        @default(now())

  repayment LoanRepayment @relation(fields: [repaymentId], references: [id])
  pledge    LoanPledge    @relation(fields: [pledgeId], references: [id])
  pledger   User          @relation(fields: [pledgerId], references: [id])

  @@unique([repaymentId, pledgeId])
  @@index([repaymentId])
  @@index([loanId])
  @@index([pledgerId])
  @@index([pledgeId])
  @@index([status])
  @@map("loan_repayment_distributions")
}

model LoanVote {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  loanId    String   @db.ObjectId
  voterId   String   @db.ObjectId
  createdAt DateTime @default(now())

  loan  LoanRequest @relation(fields: [loanId], references: [id])
  voter User        @relation(fields: [voterId], references: [id])

  @@unique([loanId, voterId])
  @@index([loanId])
  @@index([voterId])
  @@map("loan_votes")
}

