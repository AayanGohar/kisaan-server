// ─────────────────────────────────────────────
// GEO LAYER
// ─────────────────────────────────────────────

model State {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  code      String   @unique // "MH", "UP", "KA"
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())

  // Relations
  districts         District[]
  pincodes          Pincode[]
  locations         Location[]
  diseaseReports    DiseaseReport[]         @relation("DiseaseReportState")
  diseaseAggregates DiseaseAggregateDaily[]
  governmentSchemes GovernmentScheme[]
  newsArticles      NewsArticle[]
  alerts            Alert[]                 @relation("AlertState")
  communities       Community[]             @relation("CommunityState")
  blogs             Blog[]                  @relation("BlogState")

  @@index([isDeleted])
  @@map("states")
}

model District {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  stateId   String   @db.ObjectId
  name      String
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())

  // Relations
  state               State                   @relation(fields: [stateId], references: [id])
  pincodes            Pincode[]
  locations           Location[]
  marketPrices        MarketPrice[]
  diseaseReports      DiseaseReport[]         @relation("DiseaseReportDistrict")
  diseaseAggregates   DiseaseAggregateDaily[]
  laborProfiles       LaborProfile[]
  alerts              Alert[]                 @relation("AlertDistrict")
  communities         Community[]             @relation("CommunityDistrict")
  blogs               Blog[]                  @relation("BlogDistrict")
  marketplaceListings MarketplaceListing[]
  governmentSchemes   GovernmentScheme[]      @relation("DistrictGovernmentScheme")
  newsArticles        NewsArticle[]           @relation("DistrictNewsArticle")
  userEvents          UserEvent[]

  @@unique([stateId, name])
  @@index([stateId])
  @@index([isDeleted])
  @@map("districts")
}

model Pincode {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  districtId String   @db.ObjectId
  stateId    String   @db.ObjectId
  code       String   @unique
  areaName   String?
  latitude   Float?
  longitude  Float?
  isDeleted  Boolean  @default(false)
  createdAt  DateTime @default(now())

  // Relations
  district  District   @relation(fields: [districtId], references: [id])
  state     State      @relation(fields: [stateId], references: [id])
  locations Location[]
  alerts    Alert[]    @relation("AlertPincode")

  @@index([stateId])
  @@index([districtId])
  @@index([latitude, longitude]) // 2dsphere
  @@index([isDeleted])
  @@map("pincodes")
}

// ─────────────────────────────────────────────
// USERS & AUTH
// ─────────────────────────────────────────────

model User {
  id           String     @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  email        String?    @unique
  phone        String     @unique
  passwordHash String
  role         UserRole
  status       UserStatus @default(PENDING_VERIFICATION)

  preferredLanguage String  @default("hi")
  profileImageUrl   String?
  bio               String?

  // Primary location reference
  primaryLocationId String? @db.ObjectId

  isPhoneVerified Boolean   @default(false)
  isEmailVerified Boolean   @default(false)
  lastLoginAt     DateTime?

  // Fraud detection
  lastLoginIp      String?
  lastLoginDevice  String?
  failedLoginCount Int     @default(0)
  isFlagged        Boolean @default(false)
  flaggedReason    String?

  // Soft delete
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?   @db.ObjectId

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations — primary geo
  primaryLocation Location? @relation("UserPrimaryLocation", fields: [primaryLocationId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  // Relations — owned
  locations     Location[]
  farmerProfile FarmerProfile?
  laborProfile  LaborProfile?
  expertProfile ExpertProfile?
  deviceTokens  UserDeviceToken[]
  verifications UserVerification[]
  notifications Notification[]

  // Relations — authored / performed
  createdCommunities         Community[]                 @relation("CommunityCreatedBy")
  communityMemberships       CommunityMember[]
  communityJoinRequests      CommunityJoinRequest[]
  communityPosts             CommunityPost[]
  communityPostReactions     CommunityPostReaction[]
  communityComments          CommunityComment[]
  chatRoomsCreated           CommunityChatRoom[]         @relation("ChatRoomCreatedBy")
  chatMessages               CommunityChatMessage[]      @relation("ChatMessageSender")
  chatMessageEdits           CommunityChatMessageEdit[]
  chatReadReceipts           CommunityChatReadReceipt[]
  blogs                      Blog[]
  blogReactions              BlogReaction[]
  blogComments               BlogComment[]
  blogBookmarks              BlogBookmark[]
  blogViews                  BlogView[]
  contentReports             ContentReport[]             @relation("ContentReportReporter")
  contentReviewedReports     ContentReport[]             @relation("ContentReportReviewer")
  loanPledges                LoanPledge[]
  loanVotes                  LoanVote[]
  ordersBuyer                Order[]                     @relation("OrderBuyer")
  orderReviewsGiven          OrderReview[]               @relation("OrderReviewReviewer")
  orderReviewsReceived       OrderReview[]               @relation("OrderReviewReviewee")
  disputesRaised             OrderDispute[]              @relation("DisputeRaisedBy")
  disputesAssigned           OrderDispute[]              @relation("DisputeAssignedTo")
  disputesResolved           OrderDispute[]              @relation("DisputeResolvedBy")
  expertConsultsAnswered     DiseaseExpertConsult[]      @relation("ExpertConsultExpert")
  treatmentsVerified         TreatmentCatalog[]          @relation("TreatmentVerifiedBy")
  diseaseReportsExpert       DiseaseReport[]             @relation("DiseaseReportExpert")
  alertsCreated              Alert[]                     @relation("AlertCreatedBy")
  schemeApplications         SchemeApplication[]         @relation("SchemeApplicationUser")
  milestonesApproved         LoanMilestone[]             @relation("MilestoneApprovedBy")
  repaymentDistributions     LoanRepaymentDistribution[]
  userEvents                 UserEvent[]
  auditLogsPerformed         AuditLog[]
  adminActivities            AdminActivityLog[]
  rolePermissionsCreated     RolePermission[]
  permissionOverrides        UserPermissionOverride[]    @relation("PermissionOverrideUser")
  permissionOverridesGranted UserPermissionOverride[]    @relation("PermissionOverrideGrantedBy")
  featureFlagsCreated        FeatureFlag[]
  globalConfigUpdated        GlobalConfig[]
  stockLogsPerformed         ListingStockLog[]           @relation("StockLogPerformedBy")
  rateLimitLogs              RateLimitLog[]

  // Marketplace New Relations
  marketplaceItems            MarketplaceNewItem[]            @relation("SellerItems")
  marketplaceDemands          MarketplaceNewDemand[]          @relation("BuyerDemands")
  marketplacePurchaseRequests MarketplaceNewPurchaseRequest[] @relation("BuyerRequests")
  marketplaceIncomingRequests MarketplaceNewPurchaseRequest[] @relation("SellerRequests")
  marketplaceSentOffers       MarketplaceNewDemandOffer[]     @relation("SellerOffers")
  marketplaceIncomingOffers   MarketplaceNewDemandOffer[]     @relation("BuyerOffers")

  // Rental
  ownedAssets   Asset[]  @relation("OwnedAssets")
  placedBids    Bid[]    @relation("PlacedBids")
  activeRentals Rental[] @relation("ActiveRentals")

  @@index([role])
  @@index([status])
  @@index([isDeleted])
  @@index([isFlagged])
  @@index([primaryLocationId])
  @@map("users")
}

model UserVerification {
  id        String              @id @default(auto()) @map("_id") @db.ObjectId
  userId    String              @db.ObjectId
  channel   VerificationChannel
  otpHash   String
  expiresAt DateTime
  isUsed    Boolean             @default(false)
  createdAt DateTime            @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([expiresAt])
  @@map("user_verifications")
}

model UserDeviceToken {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  userId     String    @db.ObjectId
  token      String    @unique
  platform   String? // "android" | "ios" | "web"
  deviceId   String?
  isActive   Boolean   @default(true)
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([isActive])
  @@map("user_device_tokens")
}

// ─────────────────────────────────────────────
// LOCATIONS
// ─────────────────────────────────────────────

model Location {
  id          String       @id @default(auto()) @map("_id") @db.ObjectId
  userId      String       @db.ObjectId
  type        LocationType
  label       String?
  isPrimary   Boolean      @default(false)
  stateId     String       @db.ObjectId
  districtId  String       @db.ObjectId
  pincodeId   String       @db.ObjectId
  village     String?
  addressLine String?
  latitude    Float
  longitude   Float

  // Soft delete
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?   @db.ObjectId

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user                User                 @relation(fields: [userId], references: [id])
  primaryForUsers     User[]               @relation("UserPrimaryLocation")
  state               State                @relation(fields: [stateId], references: [id])
  district            District             @relation(fields: [districtId], references: [id])
  pincode             Pincode              @relation(fields: [pincodeId], references: [id])
  lands               Land[]
  warehouseItems      WarehouseItem[]
  marketplaceListings MarketplaceListing[]
  orderDeliveries     Order[]              @relation("OrderDeliveryLocation")
  laborProfiles       LaborProfile[]
  communities         Community[]          @relation("CommunityLocation")

  @@index([userId])
  @@index([userId, isPrimary])
  @@index([isDeleted])
  @@index([latitude, longitude]) // 2dsphere
  @@index([districtId])
  @@index([pincodeId])
  @@index([type])
  @@map("locations")
}

// ─────────────────────────────────────────────
// FARMER PROFILE
// ─────────────────────────────────────────────

model FarmerProfile {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @unique @db.ObjectId
  totalLandArea     Float?
  experienceYears   Int?
  aadhaarLast4      String?
  isKycVerified     Boolean @default(false)
  trustScore        Float   @default(5.0)
  totalLoansTaken   Int     @default(0)
  loansRepaidOnTime Int     @default(0)

  // Soft delete
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?   @db.ObjectId

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user                  User                   @relation(fields: [userId], references: [id])
  lands                 Land[]
  marketplaceListings   MarketplaceListing[]
  ordersAsSeller        Order[]                @relation("OrderFarmer")
  diseaseReports        DiseaseReport[]
  diseaseReportUpdates  DiseaseReportUpdate[]
  expertConsults        DiseaseExpertConsult[] @relation("ExpertConsultFarmer")
  farmerAlerts          FarmerAlert[]
  loanRequests          LoanRequest[]
  loanRepayments        LoanRepayment[]
  warehouseItems        WarehouseItem[]
  chatSessions          ChatSession[]          @relation("ChatSessionFarmer")
  schemeApplications    SchemeApplication[]
  laborBookingsAsFarmer LaborBooking[]         @relation("LaborBookingFarmer")

  @@index([trustScore])
  @@index([isDeleted])
  @@map("farmer_profiles")
}

// ─────────────────────────────────────────────
// LAND & CROPS
// ─────────────────────────────────────────────

model Land {
  id             String          @id @default(auto()) @map("_id") @db.ObjectId
  farmerId       String          @db.ObjectId
  locationId     String          @db.ObjectId
  name           String
  areaAcres      Float
  landType       LandType
  soilType       SoilType?
  irrigationType IrrigationType?
  isOrganic      Boolean         @default(false)
  surveyNumber   String?

  // Soft delete
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?   @db.ObjectId

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  farmer           FarmerProfile     @relation(fields: [farmerId], references: [id])
  location         Location          @relation(fields: [locationId], references: [id])
  crops            Crop[]
  weatherSnapshots WeatherSnapshot[]
  laborBookings    LaborBooking[]

  @@index([farmerId])
  @@index([locationId])
  @@index([isDeleted])
  @@map("lands")
}

model CropCatalog {
  id              String       @id @default(auto()) @map("_id") @db.ObjectId
  name            String       @unique
  localNames      String? // JSON: {"hi":"गेहूं","mr":"गहू"}
  category        CropCategory
  typicalSeasons  String[]     @default([])
  avgDurationDays Int?
  imageUrl        String?

  // Soft delete
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?   @db.ObjectId

  createdAt DateTime @default(now())

  // Relations
  crops             Crop[]
  marketPrices      MarketPrice[]
  communities       Community[]               @relation("CommunityCatalog")
  diseaseTreatments DiseaseCatalogTreatment[] @relation("CropCatalogDiseaseTreatment")
  blogs             Blog[]                    @relation("BlogCropCatalog")

  @@index([category])
  @@index([isDeleted])
  @@map("crop_catalog")
}

model Crop {
  id              String        @id @default(auto()) @map("_id") @db.ObjectId
  landId          String        @db.ObjectId
  catalogId       String?       @db.ObjectId
  cropName        String // denorm snapshot
  category        CropCategory?
  season          Season?
  sowingDate      DateTime?
  expectedHarvest DateTime?
  actualHarvest   DateTime?
  status          CropStatus    @default(SOWN)
  areaAcres       Float?
  expectedYieldKg Float?
  actualYieldKg   Float?
  notes           String?

  // Soft delete
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?   @db.ObjectId

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  land                Land                 @relation(fields: [landId], references: [id])
  catalog             CropCatalog?         @relation(fields: [catalogId], references: [id])
  marketplaceListings MarketplaceListing[]
  warehouseItems      WarehouseItem[]
  diseaseReports      DiseaseReport[]

  @@index([landId])
  @@index([catalogId])
  @@index([status])
  @@index([isDeleted])
  @@index([landId, season])
  @@map("crops")
}

// ─────────────────────────────────────────────
// DISEASE INTELLIGENCE
// ─────────────────────────────────────────────

model DiseaseCatalog {
  id                 String      @id @default(auto()) @map("_id") @db.ObjectId
  name               String      @unique
  localNames         String?
  scientificName     String?
  diseaseType        DiseaseType
  affectedCategories String[] // CropCategory values

  symptomsDescription  String
  visualSigns          String?
  identificationImages String[] @default([])
  spreadMechanism      String?
  favorableConditions  String?
  incubationPeriod     String?
  isOutbreakNotifiable Boolean  @default(false)

  // Soft delete
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?   @db.ObjectId

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  treatments        DiseaseCatalogTreatment[]
  diseaseReports    DiseaseReport[]
  diseaseAggregates DiseaseAggregateDaily[]

  @@index([diseaseType])
  @@index([isOutbreakNotifiable])
  @@index([isDeleted])
  @@map("disease_catalog")
}

model TreatmentCatalog {
  id              String         @id @default(auto()) @map("_id") @db.ObjectId
  name            String
  treatmentType   TreatmentType
  applicableStage TreatmentStage

  productName          String?
  activeIngredient     String?
  concentration        String?
  dosage               String?
  applicationMethod    String
  applicationFrequency String?
  waitingPeriodDays    Int?

  isOrganic         Boolean @default(false)
  safetyPrecautions String?
  phiDays           Int? // pre-harvest interval

  referenceLinks String[] @default([])
  videoUrl       String?
  costRange      String?
  availability   String?

  isVerified   Boolean @default(false)
  verifiedById String? @db.ObjectId

  efficacyRate       Float? // 0.0–1.0, recomputed from report outcomes
  efficacySampleSize Int    @default(0)

  // Soft delete
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?   @db.ObjectId

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  verifiedBy           User?                     @relation("TreatmentVerifiedBy", fields: [verifiedById], references: [id])
  diseases             DiseaseCatalogTreatment[]
  diseaseReports       DiseaseReport[]           @relation("DiseaseReportRecommendedTreatment")
  diseaseReportUpdates DiseaseReportUpdate[]

  @@index([treatmentType])
  @@index([applicableStage])
  @@index([isOrganic])
  @@index([isVerified])
  @@index([isDeleted])
  @@map("treatment_catalog")
}

// Junction: disease × treatment × stage
model DiseaseCatalogTreatment {
  id               String         @id @default(auto()) @map("_id") @db.ObjectId
  diseaseId        String         @db.ObjectId
  treatmentId      String         @db.ObjectId
  cropCatalogId    String?        @db.ObjectId
  applicableStage  TreatmentStage
  priorityRank     Int            @default(1)
  efficacyNotes    String?
  cautionNotes     String?
  verifiedByExpert Boolean        @default(false)
  createdAt        DateTime       @default(now())

  disease     DiseaseCatalog   @relation(fields: [diseaseId], references: [id])
  treatment   TreatmentCatalog @relation(fields: [treatmentId], references: [id])
  cropCatalog CropCatalog?     @relation("CropCatalogDiseaseTreatment", fields: [cropCatalogId], references: [id])

  // Note: MongoDB Prisma doesn't support @@unique on 3 fields natively in all drivers.
  // Enforce (diseaseId, treatmentId, applicableStage) uniqueness at application layer.
  @@index([diseaseId])
  @@index([treatmentId])
  @@index([diseaseId, applicableStage])
  @@map("disease_catalog_treatments")
}

model DiseaseReport {
  id               String  @id @default(auto()) @map("_id") @db.ObjectId
  cropId           String  @db.ObjectId
  farmerId         String  @db.ObjectId
  diseaseCatalogId String? @db.ObjectId

  // Geo denorm — never joined in outbreak queries
  latitude   Float?
  longitude  Float?
  districtId String? @db.ObjectId
  stateId    String? @db.ObjectId

  mediaUrl        String
  mediaType       MediaType @default(IMAGE)
  additionalMedia String[]  @default([])

  // AI output
  predictedDisease  String // snapshot at detection time
  confidenceScore   Float
  aiConfidenceLevel AIConfidenceLevel
  severity          DiseaseSeverity
  aiRecommendation  String

  recommendedTreatmentId String? @db.ObjectId

  // Expert review
  expertReviewed  Boolean   @default(false)
  expertId        String?   @db.ObjectId
  expertDiagnosis String?
  expertNotes     String?
  reviewedAt      DateTime?

  // Outbreak
  isConfirmedOutbreak Boolean @default(false)
  outbreakAlertId     String? @db.ObjectId

  // Soft delete
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?   @db.ObjectId

  createdAt DateTime @default(now())

  // Relations
  crop                 Crop                   @relation(fields: [cropId], references: [id])
  farmer               FarmerProfile          @relation(fields: [farmerId], references: [id])
  diseaseCatalog       DiseaseCatalog?        @relation(fields: [diseaseCatalogId], references: [id])
  district             District?              @relation("DiseaseReportDistrict", fields: [districtId], references: [id])
  state                State?                 @relation("DiseaseReportState", fields: [stateId], references: [id])
  recommendedTreatment TreatmentCatalog?      @relation("DiseaseReportRecommendedTreatment", fields: [recommendedTreatmentId], references: [id])
  expert               User?                  @relation("DiseaseReportExpert", fields: [expertId], references: [id])
  outbreakAlert        Alert?                 @relation("DiseaseReportOutbreakAlert", fields: [outbreakAlertId], references: [id])
  updates              DiseaseReportUpdate[]
  expertConsults       DiseaseExpertConsult[]

  @@index([cropId])
  @@index([farmerId])
  @@index([diseaseCatalogId])
  @@index([districtId])
  @@index([stateId])
  @@index([severity])
  @@index([aiConfidenceLevel])
  @@index([isConfirmedOutbreak])
  @@index([isDeleted])
  @@index([latitude, longitude]) // 2dsphere
  @@index([districtId, diseaseCatalogId, createdAt]) // outbreak aggregation
  @@index([stateId, diseaseCatalogId, createdAt])
  @@index([createdAt])
  @@map("disease_reports")
}

model DiseaseReportUpdate {
  id                 String               @id @default(auto()) @map("_id") @db.ObjectId
  reportId           String               @db.ObjectId
  farmerId           String               @db.ObjectId
  treatmentId        String?              @db.ObjectId
  updateDate         DateTime
  treatmentApplied   String?
  dosageUsed         String?
  outcome            DiseaseReportOutcome
  farmerNotes        String?
  updateMedia        String[]             @default([])
  treatmentEffective Boolean?
  createdAt          DateTime             @default(now())

  report    DiseaseReport     @relation(fields: [reportId], references: [id])
  farmer    FarmerProfile     @relation(fields: [farmerId], references: [id])
  treatment TreatmentCatalog? @relation(fields: [treatmentId], references: [id])

  @@index([reportId])
  @@index([farmerId])
  @@index([outcome])
  @@index([treatmentId])
  @@index([treatmentEffective])
  @@index([reportId, updateDate])
  @@map("disease_report_updates")
}

model DiseaseExpertConsult {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  reportId    String    @db.ObjectId
  farmerId    String    @db.ObjectId
  expertId    String?   @db.ObjectId
  question    String
  answer      String?
  isResolved  Boolean   @default(false)
  requestedAt DateTime  @default(now())
  resolvedAt  DateTime?

  report DiseaseReport @relation(fields: [reportId], references: [id])
  farmer FarmerProfile @relation("ExpertConsultFarmer", fields: [farmerId], references: [id])
  expert User?         @relation("ExpertConsultExpert", fields: [expertId], references: [id])

  @@index([reportId])
  @@index([farmerId])
  @@index([expertId])
  @@index([isResolved])
  @@map("disease_expert_consults")
}

// Precomputed nightly rollup — outbreak scan runs on this, not disease_reports
model DiseaseAggregateDaily {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  date             DateTime // start of day UTC
  districtId       String   @db.ObjectId
  stateId          String   @db.ObjectId
  diseaseCatalogId String   @db.ObjectId

  reportCount       Int
  confirmedCount    Int    @default(0)
  severityHighCount Int    @default(0)
  avgConfidence     Float?

  thresholdCrossed Boolean  @default(false)
  alertTriggered   Boolean  @default(false)
  computedAt       DateTime @default(now())

  district       District       @relation(fields: [districtId], references: [id])
  state          State          @relation(fields: [stateId], references: [id])
  diseaseCatalog DiseaseCatalog @relation(fields: [diseaseCatalogId], references: [id])

  @@unique([districtId, diseaseCatalogId, date])
  @@index([date])
  @@index([districtId])
  @@index([stateId])
  @@index([diseaseCatalogId])
  @@index([thresholdCrossed])
  @@index([stateId, diseaseCatalogId, date])
  @@map("disease_aggregates_daily")
}

// ─────────────────────────────────────────────
// MARKETPLACE
// ─────────────────────────────────────────────

model MarketPrice {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  catalogId    String   @db.ObjectId
  districtId   String   @db.ObjectId
  minPrice     Float
  maxPrice     Float
  modalPrice   Float
  unit         String   @default("quintal")
  recordedDate DateTime
  source       String?

  catalog  CropCatalog @relation(fields: [catalogId], references: [id])
  district District    @relation(fields: [districtId], references: [id])

  @@index([catalogId])
  @@index([districtId])
  @@index([catalogId, districtId, recordedDate])
  @@map("market_prices")
}

model MarketplaceListing {
  id             String        @id @default(auto()) @map("_id") @db.ObjectId
  farmerId       String        @db.ObjectId
  cropId         String        @db.ObjectId
  cropName       String // denorm snapshot
  farmerName     String // denorm snapshot
  title          String
  description    String?
  images         String[]      @default([])
  quantityKg     Float
  availableQtyKg Float
  pricePerUnit   Float
  unit           String        @default("kg")
  isNegotiable   Boolean       @default(true)
  locationId     String        @db.ObjectId
  latitude       Float
  longitude      Float
  districtId     String        @db.ObjectId
  status         ListingStatus @default(ACTIVE)
  expiresAt      DateTime?
  totalOrders    Int           @default(0)
  avgRating      Float?

  // Soft delete
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?   @db.ObjectId

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  farmer         FarmerProfile     @relation(fields: [farmerId], references: [id])
  crop           Crop              @relation(fields: [cropId], references: [id])
  location       Location          @relation(fields: [locationId], references: [id])
  district       District          @relation(fields: [districtId], references: [id])
  orders         Order[]
  stockLogs      ListingStockLog[]
  disputes       OrderDispute[]    @relation("DisputeListing")
  contentReports ContentReport[]   @relation("ContentReportListing")

  @@index([farmerId])
  @@index([status])
  @@index([isDeleted])
  @@index([latitude, longitude]) // 2dsphere
  @@index([districtId])
  @@index([cropName])
  @@index([status, districtId])
  @@index([expiresAt])
  @@map("marketplace_listings")
}

// Immutable stock movement ledger
model ListingStockLog {
  id             String          @id @default(auto()) @map("_id") @db.ObjectId
  listingId      String          @db.ObjectId
  changeType     StockChangeType
  quantityChange Float // positive = added, negative = deducted
  quantityAfter  Float // available_qty_kg after this event
  referenceType  String? // "order" | "manual" | "warehouse_transfer"
  referenceId    String?         @db.ObjectId
  performedById  String?         @db.ObjectId
  notes          String?
  createdAt      DateTime        @default(now())

  listing     MarketplaceListing @relation(fields: [listingId], references: [id])
  performedBy User?              @relation("StockLogPerformedBy", fields: [performedById], references: [id])

  @@index([listingId])
  @@index([changeType])
  @@index([listingId, createdAt])
  @@index([referenceId])
  @@map("listing_stock_logs")
}

model Order {
  id                      String      @id @default(auto()) @map("_id") @db.ObjectId
  listingId               String      @db.ObjectId
  buyerId                 String      @db.ObjectId
  farmerId                String      @db.ObjectId // denorm
  quantityKg              Float
  pricePerUnit            Float
  negotiatedPrice         Float?
  totalAmount             Float
  status                  OrderStatus @default(PENDING)
  deliveryLocationId      String?     @db.ObjectId
  deliveryAddressSnapshot String?
  buyerNote               String?
  cancelReason            String?
  confirmedAt             DateTime?
  shippedAt               DateTime?
  deliveredAt             DateTime?
  cancelledAt             DateTime?

  // Soft delete
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?   @db.ObjectId

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  listing          MarketplaceListing @relation(fields: [listingId], references: [id])
  buyer            User               @relation("OrderBuyer", fields: [buyerId], references: [id])
  farmer           FarmerProfile      @relation("OrderFarmer", fields: [farmerId], references: [id])
  deliveryLocation Location?          @relation("OrderDeliveryLocation", fields: [deliveryLocationId], references: [id])
  transaction      Transaction?
  review           OrderReview?
  disputes         OrderDispute[]

  @@index([buyerId])
  @@index([farmerId])
  @@index([listingId])
  @@index([status])
  @@index([isDeleted])
  @@index([buyerId, status])
  @@index([createdAt])
  @@map("orders")
}

model Transaction {
  id               String         @id @default(auto()) @map("_id") @db.ObjectId
  orderId          String         @unique @db.ObjectId
  grossAmount      Float
  platformFee      Float          @default(0)
  farmerPayout     Float
  paymentMethod    PaymentMethod?
  paymentStatus    PaymentStatus  @default(PENDING)
  paymentReference String?
  paidAt           DateTime?
  refundedAt       DateTime?
  refundAmount     Float?
  refundReason     String?
  paymentIp        String?
  paymentDevice    String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  order Order @relation(fields: [orderId], references: [id])

  @@index([paymentStatus])
  @@index([paymentReference])
  @@map("transactions")
}

model OrderReview {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  orderId    String   @unique @db.ObjectId
  reviewerId String   @db.ObjectId
  revieweeId String   @db.ObjectId
  rating     Int // 1–5
  comment    String?
  createdAt  DateTime @default(now())

  order    Order @relation(fields: [orderId], references: [id])
  reviewer User  @relation("OrderReviewReviewer", fields: [reviewerId], references: [id])
  reviewee User  @relation("OrderReviewReviewee", fields: [revieweeId], references: [id])

  @@index([revieweeId])
  @@index([revieweeId, rating])
  @@map("order_reviews")
}

model OrderDispute {
  id              String        @id @default(auto()) @map("_id") @db.ObjectId
  orderId         String        @db.ObjectId
  listingId       String?       @db.ObjectId
  raisedById      String        @db.ObjectId
  reason          DisputeReason
  description     String
  evidenceMedia   String[]      @default([])
  status          DisputeStatus @default(OPEN)
  assignedToId    String?       @db.ObjectId
  resolutionNotes String?
  refundAmount    Float?
  resolvedById    String?       @db.ObjectId
  raisedAt        DateTime      @default(now())
  resolvedAt      DateTime?

  order      Order               @relation(fields: [orderId], references: [id])
  listing    MarketplaceListing? @relation("DisputeListing", fields: [listingId], references: [id])
  raisedBy   User                @relation("DisputeRaisedBy", fields: [raisedById], references: [id])
  assignedTo User?               @relation("DisputeAssignedTo", fields: [assignedToId], references: [id])
  resolvedBy User?               @relation("DisputeResolvedBy", fields: [resolvedById], references: [id])

  @@index([orderId])
  @@index([raisedById])
  @@index([status])
  @@index([assignedToId])
  @@index([status, raisedAt])
  @@map("order_disputes")
}

// ─────────────────────────────────────────────
// WEATHER
// ─────────────────────────────────────────────

model WeatherSnapshot {
  id           String            @id @default(auto()) @map("_id") @db.ObjectId
  landId       String            @db.ObjectId
  latitude     Float?
  longitude    Float?
  temperatureC Float?
  humidityPct  Float?
  rainfallMm   Float?
  windSpeedKmh Float?
  condition    WeatherCondition?
  uvIndex      Float?
  source       String?
  forecastFor  DateTime?
  recordedAt   DateTime // TTL: 90 days

  land Land @relation(fields: [landId], references: [id])

  @@index([landId])
  @@index([landId, recordedAt])
  @@index([recordedAt]) // TTL target
  @@map("weather_snapshots")
}

// ─────────────────────────────────────────────
// ALERTS
// ─────────────────────────────────────────────

model Alert {
  id              String           @id @default(auto()) @map("_id") @db.ObjectId
  type            AlertType
  severity        AlertSeverity
  title           String
  message         String
  targetLevel     AlertTargetLevel
  stateId         String?          @db.ObjectId
  districtId      String?          @db.ObjectId
  pincodeId       String?          @db.ObjectId
  centerLatitude  Float?
  centerLongitude Float?
  radiusKm        Float?
  isActive        Boolean          @default(true)
  createdById     String?          @db.ObjectId
  expiresAt       DateTime?

  // Soft delete
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?   @db.ObjectId

  createdAt DateTime @default(now())

  // Relations
  state          State?          @relation("AlertState", fields: [stateId], references: [id])
  district       District?       @relation("AlertDistrict", fields: [districtId], references: [id])
  pincode        Pincode?        @relation("AlertPincode", fields: [pincodeId], references: [id])
  createdBy      User?           @relation("AlertCreatedBy", fields: [createdById], references: [id])
  farmerAlerts   FarmerAlert[]
  diseaseReports DiseaseReport[] @relation("DiseaseReportOutbreakAlert")

  @@index([type])
  @@index([severity])
  @@index([targetLevel])
  @@index([stateId])
  @@index([districtId])
  @@index([isActive])
  @@index([isDeleted])
  @@index([isActive, targetLevel])
  @@index([centerLatitude, centerLongitude]) // 2dsphere
  @@index([expiresAt])
  @@map("alerts")
}

model FarmerAlert {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  farmerId    String    @db.ObjectId
  alertId     String    @db.ObjectId
  isRead      Boolean   @default(false)
  readAt      DateTime?
  deliveredAt DateTime  @default(now())

  farmer FarmerProfile @relation(fields: [farmerId], references: [id])
  alert  Alert         @relation(fields: [alertId], references: [id])

  @@unique([farmerId, alertId])
  @@index([farmerId])
  @@index([alertId])
  @@index([farmerId, isRead])
  @@map("farmer_alerts")
}

