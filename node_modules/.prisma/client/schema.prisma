model GovernmentScheme {
  id               String          @id @default(auto()) @map("_id") @db.ObjectId
  title            String
  description      String
  eligibility      String?
  officialLink     String?
  schemeCategory   SchemeCategory?
  maxBenefitAmount Float?
  benefitUnit      String?
  isNational       Boolean         @default(false)
  stateId          String?         @db.ObjectId
  districtId       String?         @db.ObjectId
  isActive         Boolean         @default(true)
  deadline         DateTime?

  // Soft delete
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?   @db.ObjectId

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  state        State?              @relation(fields: [stateId], references: [id])
  district     District?           @relation("DistrictGovernmentScheme", fields: [districtId], references: [id])
  applications SchemeApplication[]

  @@index([isNational])
  @@index([stateId])
  @@index([districtId])
  @@index([schemeCategory])
  @@index([isActive])
  @@index([isDeleted])
  @@index([deadline])
  @@index([isActive, isNational])
  @@index([isActive, stateId])
  @@map("government_schemes")
}

model SchemeApplication {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  schemeId  String   @db.ObjectId
  farmerId  String   @db.ObjectId
  userId    String   @db.ObjectId
  status    String   @default("APPLIED") // APPLIED|UNDER_REVIEW|APPROVED|REJECTED
  notes     String?
  appliedAt DateTime @default(now())

  scheme GovernmentScheme @relation(fields: [schemeId], references: [id])
  farmer FarmerProfile    @relation(fields: [farmerId], references: [id])
  user   User             @relation("SchemeApplicationUser", fields: [userId], references: [id])

  @@unique([farmerId, schemeId])
  @@index([schemeId])
  @@index([farmerId])
  @@index([status])
  @@map("scheme_applications")
}

model NewsArticle {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  summary     String?
  content     String
  source      String?
  sourceUrl   String?
  imageUrl    String?
  tags        String[]  @default([])
  catalogIds  String[]  @default([]) @db.ObjectId
  isNational  Boolean   @default(false)
  stateId     String?   @db.ObjectId
  districtId  String?   @db.ObjectId
  isPublished Boolean   @default(false)
  publishedAt DateTime?

  // Soft delete
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?   @db.ObjectId

  createdAt DateTime @default(now())

  state    State?    @relation(fields: [stateId], references: [id])
  district District? @relation("DistrictNewsArticle", fields: [districtId], references: [id])

  @@unique([sourceUrl])
  @@index([isNational])
  @@index([stateId])
  @@index([districtId])
  @@index([isDeleted])
  @@index([isPublished, publishedAt])
  @@map("news_articles")
}

// ─────────────────────────────────────────────
// COMMUNITY
// ─────────────────────────────────────────────

model Community {
  id                String        @id @default(auto()) @map("_id") @db.ObjectId
  name              String
  description       String?
  createdById       String        @db.ObjectId
  type              CommunityType
  stateId           String?       @db.ObjectId
  districtId        String?       @db.ObjectId
  locationId        String?       @db.ObjectId
  centerLatitude    Float?
  centerLongitude   Float?
  radiusKm          Float?
  catalogId         String?       @db.ObjectId
  cropName          String? // denorm
  isSystemGenerated Boolean       @default(false)
  isPrivate         Boolean       @default(false)
  isActive          Boolean       @default(true)
  coverImageUrl     String?
  memberCount       Int           @default(0)
  postCount         Int           @default(0)

  // Soft delete
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?   @db.ObjectId

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  createdBy    User                   @relation("CommunityCreatedBy", fields: [createdById], references: [id])
  state        State?                 @relation("CommunityState", fields: [stateId], references: [id])
  district     District?              @relation("CommunityDistrict", fields: [districtId], references: [id])
  location     Location?              @relation("CommunityLocation", fields: [locationId], references: [id])
  catalog      CropCatalog?           @relation("CommunityCatalog", fields: [catalogId], references: [id])
  members      CommunityMember[]
  joinRequests CommunityJoinRequest[]
  posts        CommunityPost[]
  chatRooms    CommunityChatRoom[]
  loanRequests LoanRequest[]

  @@index([createdById])
  @@index([type])
  @@index([districtId])
  @@index([stateId])
  @@index([catalogId])
  @@index([isActive])
  @@index([isDeleted])
  @@index([isActive, type])
  @@index([centerLatitude, centerLongitude]) // 2dsphere
  @@map("communities")
}

enum JoinRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model CommunityJoinRequest {
  id          String            @id @default(auto()) @map("_id") @db.ObjectId
  communityId String            @db.ObjectId
  userId      String            @db.ObjectId
  status      JoinRequestStatus @default(PENDING)
  notes       String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  community Community @relation(fields: [communityId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@unique([communityId, userId])
  @@index([communityId])
  @@index([userId])
  @@index([status])
  @@map("community_join_requests")
}

model CommunityMember {
  id          String              @id @default(auto()) @map("_id") @db.ObjectId
  communityId String              @db.ObjectId
  userId      String              @db.ObjectId
  role        CommunityMemberRole @default(MEMBER)
  invitedById String?             @db.ObjectId
  joinedAt    DateTime            @default(now())

  community Community @relation(fields: [communityId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@unique([communityId, userId])
  @@index([communityId])
  @@index([userId])
  @@index([communityId, role])
  @@map("community_members")
}

model CommunityPost {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  communityId  String   @db.ObjectId
  authorId     String   @db.ObjectId
  content      String
  images       String[] @default([])
  videoUrl     String?
  likeCount    Int      @default(0)
  commentCount Int      @default(0)
  isPinned     Boolean  @default(false)

  // Soft delete
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?   @db.ObjectId

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  community      Community               @relation(fields: [communityId], references: [id])
  author         User                    @relation(fields: [authorId], references: [id])
  reactions      CommunityPostReaction[]
  comments       CommunityComment[]
  contentReports ContentReport[]         @relation("ContentReportPost")

  @@index([communityId])
  @@index([authorId])
  @@index([isDeleted])
  @@index([isPinned])
  @@index([communityId, createdAt])
  @@map("community_posts")
}

model CommunityPostReaction {
  id        String           @id @default(auto()) @map("_id") @db.ObjectId
  postId    String           @db.ObjectId
  userId    String           @db.ObjectId
  type      PostReactionType @default(LIKE)
  createdAt DateTime         @default(now())

  post CommunityPost @relation(fields: [postId], references: [id])
  user User          @relation(fields: [userId], references: [id])

  @@unique([postId, userId])
  @@index([postId])
  @@map("community_post_reactions")
}

model CommunityComment {
  id       String  @id @default(auto()) @map("_id") @db.ObjectId
  postId   String  @db.ObjectId
  authorId String  @db.ObjectId
  parentId String? @db.ObjectId // self-relation for nested replies

  content String

  // Soft delete
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?   @db.ObjectId

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  post           CommunityPost      @relation(fields: [postId], references: [id])
  author         User               @relation(fields: [authorId], references: [id])
  parent         CommunityComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  replies        CommunityComment[] @relation("CommentReplies")
  contentReports ContentReport[]    @relation("ContentReportComment")

  @@index([postId])
  @@index([authorId])
  @@index([parentId])
  @@index([isDeleted])
  @@index([postId, createdAt])
  @@map("community_comments")
}

// Named chat channels within a community
model CommunityChatRoom {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  communityId   String    @db.ObjectId
  name          String
  slug          String
  description   String?
  isDefault     Boolean   @default(false)
  isReadOnly    Boolean   @default(false)
  createdById   String    @db.ObjectId
  lastMessageAt DateTime?
  messageCount  Int       @default(0)

  // Soft delete
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?   @db.ObjectId

  createdAt DateTime @default(now())

  // Relations
  community    Community                  @relation(fields: [communityId], references: [id])
  createdBy    User                       @relation("ChatRoomCreatedBy", fields: [createdById], references: [id])
  messages     CommunityChatMessage[]
  readReceipts CommunityChatReadReceipt[]

  @@unique([communityId, slug])
  @@index([communityId])
  @@index([isDeleted])
  @@index([lastMessageAt])
  @@map("community_chat_rooms")
}

// TTL: 365 days on createdAt
model CommunityChatMessage {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  roomId      String   @db.ObjectId
  communityId String   @db.ObjectId // denorm
  senderId    String   @db.ObjectId
  content     String
  images      String[] @default([])
  replyToId   String?  @db.ObjectId
  isSystem    Boolean  @default(false)

  // Soft delete
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?   @db.ObjectId

  createdAt DateTime  @default(now()) // TTL target
  editedAt  DateTime?

  // Relations
  room           CommunityChatRoom          @relation(fields: [roomId], references: [id])
  sender         User                       @relation("ChatMessageSender", fields: [senderId], references: [id])
  replyTo        CommunityChatMessage?      @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  replies        CommunityChatMessage[]     @relation("MessageReplies")
  editHistory    CommunityChatMessageEdit[]
  contentReports ContentReport[]            @relation("ContentReportChatMsg")

  @@index([roomId])
  @@index([communityId])
  @@index([senderId])
  @@index([replyToId])
  @@index([isDeleted])
  @@index([roomId, createdAt])
  @@index([createdAt]) // TTL target
  @@map("community_chat_messages")
}

model CommunityChatMessageEdit {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  messageId       String   @db.ObjectId
  previousContent String
  editedById      String   @db.ObjectId
  editedAt        DateTime @default(now())

  message  CommunityChatMessage @relation(fields: [messageId], references: [id])
  editedBy User                 @relation(fields: [editedById], references: [id])

  @@index([messageId])
  @@index([editedAt])
  @@map("community_chat_message_edits")
}

model CommunityChatReadReceipt {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  roomId        String   @db.ObjectId
  userId        String   @db.ObjectId
  lastReadAt    DateTime
  lastMessageId String?  @db.ObjectId

  room CommunityChatRoom @relation(fields: [roomId], references: [id])
  user User              @relation(fields: [userId], references: [id])

  @@unique([roomId, userId])
  @@index([roomId])
  @@index([userId])
  @@map("community_chat_read_receipts")
}

model ContentReport {
  id                     String       @id @default(auto()) @map("_id") @db.ObjectId
  reporterId             String       @db.ObjectId
  postId                 String?      @db.ObjectId
  commentId              String?      @db.ObjectId
  chatMsgId              String?      @db.ObjectId
  listingId              String?      @db.ObjectId
  blogId                 String?      @db.ObjectId
  newMarketplaceItemId   String?      @db.ObjectId
  newMarketplaceDemandId String?      @db.ObjectId
  reason                 ReportReason
  description            String?
  status                 String       @default("OPEN") // OPEN|REVIEWED|ACTIONED|DISMISSED
  reviewedById           String?      @db.ObjectId
  reviewedAt             DateTime?
  createdAt              DateTime     @default(now())

  reporter   User                  @relation("ContentReportReporter", fields: [reporterId], references: [id])
  reviewedBy User?                 @relation("ContentReportReviewer", fields: [reviewedById], references: [id])
  post       CommunityPost?        @relation("ContentReportPost", fields: [postId], references: [id])
  comment    CommunityComment?     @relation("ContentReportComment", fields: [commentId], references: [id])
  chatMsg    CommunityChatMessage? @relation("ContentReportChatMsg", fields: [chatMsgId], references: [id])
  listing    MarketplaceListing?   @relation("ContentReportListing", fields: [listingId], references: [id])
